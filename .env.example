# Buzzket environment variables.
# Copy to `.env` and fill in once a Supabase project is connected.

# --- Public (shipped to the browser; safe) ---
# Used by the browser client for Auth + RLS-protected reads.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-only (NEVER expose to the client) ---
# Service-role key bypasses RLS; used by server functions / RPC calls.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
